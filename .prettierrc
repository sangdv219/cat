{
  "tabWidth": 2,
  "bracketSpacing": true,
  "semi": false,
  "singleQuote": true,
  "printWidth": 100,
  "trailingComma": "all",
  "arrowParens": "always",
  "quoteProps": "consistent",
  "bracketSameLine": false,
  "singleAttributePerLine": false,
  "useTabs": false,
  "proseWrap": "",
  "htmlWhitespaceSensitivity": "css",
  "embeddedLanguageFormatting": "auto",
  "endOfLine": "lf"
}
